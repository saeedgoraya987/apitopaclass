{
  "version": 2,
  "routes": [
    {
      "src": "/api/stats",
      "dest": "/api/stats.js",
      "methods": ["GET", "OPTIONS"]
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
